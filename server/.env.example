# MongoDB Connection String
# For local MongoDB: mongodb://localhost:27017/PathoLabDB
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/PathoLabDB
MONGODB_URI=mongodb://localhost:27017/PathoLabDB

PORT=5000

# JWT Secret for token authentication (generate a strong random string for production)
JWT_SECRET=your-secret-key-change-in-production

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000
